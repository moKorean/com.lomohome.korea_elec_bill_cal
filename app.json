      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          },
          "options": {
            "singular": true,
            "title": {
              "en": "Select a device",
              "ko": "기기 선택"
            },
            "subtitle": {
              "en": "Select the device to measure electricity usage",
              "ko": "전력 사용량을 측정할 기기를 선택해주세요"
            }
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Source Device",
            "ko": "소스 디바이스"
          },
          "children": [
            {
              "id": "homey_device_id",
              "type": "label",
              "label": {
                "en": "Device ID",
                "ko": "디바이스 ID"
              },
              "value": ""
            },
            {
              "id": "homey_device_name",
