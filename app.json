    "local"
  ],
  "source": "https://github.com/mokorean/com.lomohome.korea_elec_bill_cal",
  "flow": {
    "triggers": [
      {
        "id": "budget_exceeded",
        "title": {
          "en": "Forecast bill exceeds monthly budget",
          "ko": "예상 요금이 목표 예산을 초과하면"
        },
        "hint": {
          "en": "Triggers when this month's forecast bill first rises above the monthly budget set in device settings.",
          "ko": "이번달 예상 요금이 디바이스 설정의 월 목표 예산을 처음으로 넘어설 때 실행됩니다."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          }
        ],
        "tokens": [
          {
            "name": "forecast",
            "type": "number",
            "title": {
              "en": "Forecast bill (won)",
              "ko": "예상 요금"
            },
            "example": 52000
          },
          {
            "name": "budget",
            "type": "number",
            "title": {
              "en": "Monthly budget (won)",
              "ko": "월 목표 예산"
            },
            "example": 50000
          }
        ]
      },
      {
        "id": "kwh_step_changed",
        "title": {
          "en": "Progressive step changed",
          "ko": "누진 단계가 변경되면"
        },
        "hint": {
          "en": "Triggers when the progressive rate step changes",
          "ko": "누진 단계가 변경될 때 실행됩니다"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          }
        ],
        "tokens": [
          {
            "name": "old_step",
            "type": "number",
            "title": {
              "en": "Previous step",
              "ko": "이전 단계"
            },
            "example": 1
          },
          {
            "name": "new_step",
            "type": "number",
            "title": {
              "en": "New step",
              "ko": "새 단계"
            },
            "example": 2
          }
        ]
      },
      {
        "id": "kwh_step_increased",
        "title": {
          "en": "Progressive step increased",
          "ko": "누진 단계가 올라가면"
        },
        "hint": {
          "en": "Triggers only when the progressive rate step goes up (not on the reset at the meter-reading day)",
          "ko": "누진 단계가 올라갈 때만 실행됩니다 (검침일 초기화로 내려갈 때는 실행되지 않음)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          }
        ],
        "tokens": [
          {
            "name": "old_step",
            "type": "number",
            "title": {
              "en": "Previous step",
              "ko": "이전 단계"
            },
            "example": 1
          },
          {
            "name": "new_step",
            "type": "number",
            "title": {
              "en": "New step",
              "ko": "새 단계"
            },
            "example": 2
          }
        ]
      },
      {
        "id": "money_exceeds_trigger",
        "title": {
          "en": "This month cost rises above amount",
          "ko": "이번달 요금이 금액을 초과하면"
        },
        "titleFormatted": {
          "en": "This month cost rises above [[amount]] won",
          "ko": "이번달 사용량 요금이 [[amount]]원을 초과하면"
        },
        "hint": {
          "en": "Triggers when this month's cost first rises above the given amount.",
          "ko": "이번달 사용량 요금이 지정한 금액을 처음으로 넘어설 때 실행됩니다."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          },
          {
            "type": "number",
            "name": "amount",
            "title": {
              "en": "Amount (won)",
              "ko": "금액 (원)"
            },
            "min": 0,
            "step": 1000
          }
        ]
      },
      {
        "id": "new_billing_period",
        "title": {
          "en": "New billing period started",
          "ko": "새 청구기간이 시작되면"
        },
        "hint": {
          "en": "Triggers on the meter-reading day when a new billing period begins. Provides last period's usage and bill.",
          "ko": "검침일에 새 청구기간이 시작될 때 실행됩니다. 지난 청구기간의 사용량과 요금을 제공합니다."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          }
        ],
        "tokens": [
          {
            "name": "last_month_usage",
            "type": "number",
            "title": {
              "en": "Last period usage (kWh)",
              "ko": "지난 청구기간 사용량"
            },
            "example": 320
          },
          {
            "name": "last_month_bill",
            "type": "number",
            "title": {
              "en": "Last period bill (won)",
              "ko": "지난 청구기간 요금"
            },
            "example": 45000
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "load_period_is",
        "title": {
          "en": "Current load period !{{is|is not}} ...",
          "ko": "현재 부하시간대가 ...!{{이면|아니면}}"
        },
        "titleFormatted": {
          "en": "Current load period !{{is|is not}} [[period]]",
          "ko": "현재 부하시간대가 [[period]] !{{이면|아니면}}"
        },
        "hint": {
          "en": "Checks the current time-of-use load period (off/mid/on-peak). Useful to shift heavy appliances to off-peak hours.",
          "ko": "현재 시간대의 부하 구분(경/중/최대부하)을 확인합니다. 고전력 기기를 경부하 시간대로 미루는 자동화에 유용합니다."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          },
          {
            "type": "dropdown",
            "name": "period",
            "values": [
              {
                "id": "off",
                "label": {
                  "en": "Off-peak",
                  "ko": "경부하"
                }
              },
              {
                "id": "mid",
                "label": {
                  "en": "Mid-peak",
                  "ko": "중간부하"
                }
              },
              {
                "id": "peak",
                "label": {
                  "en": "On-peak",
                  "ko": "최대부하"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "money_exceeds",
        "title": {
          "en": "This month cost !{{exceeds|doesn't exceed}} amount",
          "ko": "이번달 예상 요금이 금액을 !{{초과|초과하지 않으면}}"
        },
        "titleFormatted": {
          "en": "This month cost !{{exceeds|doesn't exceed}} [[amount]] won",
          "ko": "이번달 예상 요금이 [[amount]]원을 !{{초과|초과하지 않으면}}"
        },
        "hint": {
          "en": "Check if this month's estimated cost exceeds the specified amount",
          "ko": "이번달 예상 요금이 지정한 금액을 초과하는지 확인합니다"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          },
          {
            "type": "number",
            "name": "amount",
            "title": {
              "en": "Amount (₩)",
              "ko": "금액 (원)"
            },
            "min": 0,
            "step": 1000
          }
        ]
      }
    ]
  },
