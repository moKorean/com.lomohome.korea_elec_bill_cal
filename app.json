{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.lomohome.korea_elec_bill_cal",
  "version": "1.0.0",
  "compatibility": ">=12.9.0",
  "brandColor": "#0066cc",
  "sdk": 3,
  "name": {
    "en": "Korea Electricity Bill Calculator",
    "ko": "한국 전력 요금 계산기"
  },
  "description": {
    "en": "Calculate Korean electricity bills based on KEPCO progressive rate system. Track usage and estimate monthly costs.",
    "ko": "한국전력(KEPCO) 누진제 요금 체계를 기반으로 전기 요금을 계산합니다. 사용량을 추적하고 월별 예상 요금을 확인하세요."
  },
  "category": "energy",
  "tags": {
    "en": [
      "KEPCO",
      "Korea",
      "electricity",
      "bill",
      "calculator",
      "progressive rate",
      "energy",
      "power",
      "utility bill",
      "cost",
      "tariff",
      "pricing"
    ],
    "ko": [
      "한국전력",
      "전기요금",
      "누진제",
      "전력",
      "에너지",
      "요금계산",
      "KEPCO"
    ]
  },
  "permissions": [
    "homey:manager:api",
    "homey:manager:geolocation"
  ],
  "images": {
    "large": "/assets/images/large.jpg",
    "small": "/assets/images/small.jpg"
  },
  "author": {
    "name": "LomoHome",
    "email": "mokorean@gmail.com"
  },
  "copyright": "LomoHome (mokorean@gmail.com)",
  "license": "GPL-3.0-or-later",
  "contributors": {
    "developers": [
      {
        "name": "LomoHome",
        "email": "mokorean@gmail.com"
      }
    ]
  },
  "bugs": {
    "url": "https://github.com/mokorean/com.lomohome.korea_elec_bill_cal/issues"
  },
  "platforms": [
    "local"
  ],
  "source": "https://github.com/mokorean/com.lomohome.korea_elec_bill_cal",
  "flow": {
    "triggers": [
      {
        "id": "kwh_step_changed",
        "title": {
          "en": "Progressive step changed",
          "ko": "누진 단계가 변경되면"
        },
        "hint": {
          "en": "Triggers when the progressive rate step changes",
          "ko": "누진 단계가 변경될 때 실행됩니다"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          }
        ],
        "tokens": [
          {
            "name": "old_step",
            "type": "number",
            "title": {
              "en": "Previous step",
              "ko": "이전 단계"
            },
            "example": 1
          },
          {
            "name": "new_step",
            "type": "number",
            "title": {
              "en": "New step",
              "ko": "새 단계"
            },
            "example": 2
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "money_exceeds",
        "title": {
          "en": "This month cost !{{exceeds|doesn't exceed}} amount",
          "ko": "이번달 예상 요금이 금액을 !{{초과|초과하지 않으면}}"
        },
        "titleFormatted": {
          "en": "This month cost !{{exceeds|doesn't exceed}} [[amount]] won",
          "ko": "이번달 예상 요금이 [[amount]]원을 !{{초과|초과하지 않으면}}"
        },
        "hint": {
          "en": "Check if this month's estimated cost exceeds the specified amount",
          "ko": "이번달 예상 요금이 지정한 금액을 초과하는지 확인합니다"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=korea_elec"
          },
          {
            "type": "number",
            "name": "amount",
            "title": {
              "en": "Amount (₩)",
              "ko": "금액 (원)"
            },
            "min": 0,
            "step": 1000
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Korea Electricity Meter",
        "ko": "한국 전력 요금 계산기"
      },
      "class": "sensor",
      "capabilities": [
        "meter_money_this_month",
        "meter_kwh_this_month",
        "kwh_step",
        "meter_tariff",
        "meter_kwh_last_hour",
        "meter_kwh_last_day",
        "meter_kwh_last_month",
        "meter_kwh_this_year",
        "meter_money_this_year",
        "meter_power"
      ],
      "capabilitiesOptions": {
        "meter_power": {
          "title": {
            "en": "Total Energy",
            "ko": "총 사용량"
          },
          "decimals": 2
        },
        "meter_kwh_this_month": {
          "title": {
            "en": "This Month",
            "ko": "이번달 사용량"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 1
        },
        "meter_kwh_this_year": {
          "title": {
            "en": "This Year",
            "ko": "올해 사용량"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 1
        },
        "meter_kwh_last_hour": {
          "title": {
            "en": "Last Hour",
            "ko": "지난 시간"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 2
        },
        "meter_kwh_last_day": {
          "title": {
            "en": "Yesterday",
            "ko": "어제"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 1
        },
        "meter_kwh_last_month": {
          "title": {
            "en": "Last Month",
            "ko": "지난달"
          },
          "units": {
            "en": "kWh"
          },
          "decimals": 1
        },
        "meter_money_this_month": {
          "title": {
            "en": "This Month Cost",
            "ko": "이번달 예상 요금"
          }
        },
        "meter_money_this_year": {
          "title": {
            "en": "This Year Cost",
            "ko": "올해 누적 요금"
          }
        },
        "meter_tariff": {
          "title": {
            "en": "Current Rate",
            "ko": "현재 단가"
          },
          "units": {
            "en": "₩/kWh"
          },
          "decimals": 1
        },
        "kwh_step": {
          "title": {
            "en": "Progressive Step",
            "ko": "누진 단계"
          },
          "decimals": 0
        }
      },
      "images": {
        "large": "./assets/images/large.jpg",
        "small": "./assets/images/small.jpg"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          },
          "options": {
            "singular": true,
            "title": {
              "en": "Select a device",
              "ko": "기기 선택"
            },
            "subtitle": {
              "en": "Select the device to measure electricity usage",
              "ko": "전력 사용량을 측정할 기기를 선택해주세요"
            }
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "Source Device",
            "ko": "소스 디바이스"
          },
          "children": [
            {
              "id": "homey_device_id",
              "type": "label",
              "label": {
                "en": "Device ID",
                "ko": "디바이스 ID"
              },
              "value": ""
            },
            {
              "id": "homey_device_name",
              "type": "label",
              "label": {
                "en": "Device Name",
                "ko": "디바이스 이름"
              },
              "value": ""
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "KEPCO Settings",
            "ko": "한전 설정"
          },
          "children": [
            {
              "id": "check_day",
              "type": "number",
              "label": {
                "en": "Meter Reading Day",
                "ko": "검침일"
              },
              "hint": {
                "en": "Day of month when meter is read (1-31, 0 for last day)",
                "ko": "검침일 (1-31, 0은 말일)"
              },
              "value": 1,
              "min": 0,
              "max": 31
            },
            {
              "id": "pressure",
              "type": "dropdown",
              "label": {
                "en": "Voltage Type",
                "ko": "전압 구분"
              },
              "hint": {
                "en": "Low voltage (most residential) or High voltage",
                "ko": "저압(일반 가정) 또는 고압"
              },
              "value": "low",
              "values": [
                {
                  "id": "low",
                  "label": {
                    "en": "Low Voltage (Residential)",
                    "ko": "저압 (주거용)"
                  }
                },
                {
                  "id": "high",
                  "label": {
                    "en": "High Voltage",
                    "ko": "고압"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Discount Settings",
            "ko": "할인 설정"
          },
          "children": [
            {
              "id": "bigfam_dc",
              "type": "dropdown",
              "label": {
                "en": "Large Family Discount",
                "ko": "대가족 할인"
              },
              "value": "0",
              "values": [
                {
                  "id": "0",
                  "label": {
                    "en": "None",
                    "ko": "없음"
                  }
                },
                {
                  "id": "1",
                  "label": {
                    "en": "5+ members / Newborn / 3+ children",
                    "ko": "5인 이상 / 출산가구 / 3자녀 이상"
                  }
                },
                {
                  "id": "2",
                  "label": {
                    "en": "Life Support Equipment",
                    "ko": "생명유지장치"
                  }
                }
              ]
            },
            {
              "id": "welfare_dc",
              "type": "dropdown",
              "label": {
                "en": "Welfare Discount",
                "ko": "복지 할인"
              },
              "value": "0",
              "values": [
                {
                  "id": "0",
                  "label": {
                    "en": "None",
                    "ko": "없음"
                  }
                },
                {
                  "id": "1",
                  "label": {
                    "en": "Veterans / Disabled",
                    "ko": "유공자 / 장애인"
                  }
                },
                {
                  "id": "2",
                  "label": {
                    "en": "Social Welfare Facility",
                    "ko": "사회복지시설"
                  }
                },
                {
                  "id": "3",
                  "label": {
                    "en": "Basic Livelihood (Living/Medical)",
                    "ko": "기초생활 (생계/의료)"
                  }
                },
                {
                  "id": "4",
                  "label": {
                    "en": "Basic Livelihood (Housing/Education)",
                    "ko": "기초생활 (주거/교육)"
                  }
                },
                {
                  "id": "5",
                  "label": {
                    "en": "Near-poverty",
                    "ko": "차상위계층"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Meter Values",
            "ko": "미터 값"
          },
          "children": [
            {
              "id": "meter_total_start",
              "type": "number",
              "label": {
                "en": "Total Meter Offset (kWh)",
                "ko": "총 사용량 시작값 (kWh)"
              },
              "hint": {
                "en": "Offset to add to source device meter value. Default 0 uses source value as-is.",
                "ko": "측정 센서 값에 더할 오프셋. 기본값 0은 센서 값을 그대로 사용."
              },
              "value": 0,
              "decimals": 2
            },
            {
              "id": "meter_month_start",
              "type": "number",
              "label": {
                "en": "Month Start (kWh)",
                "ko": "월초 미터값 (kWh)"
              },
              "value": 0,
              "decimals": 2
            },
            {
              "id": "meter_year_start",
              "type": "number",
              "label": {
                "en": "Year Start (kWh)",
                "ko": "연초 미터값 (kWh)"
              },
              "value": 0,
              "decimals": 2
            }
          ]
        }
      ],
      "id": "korea_elec"
