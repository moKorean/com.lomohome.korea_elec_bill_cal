    {
      "type": "group",
      "label": {
        "en": "KEPCO Settings",
        "ko": "한전 설정"
      },
      "children": [
        {
          "id": "check_day",
          "type": "number",
          "label": {
            "en": "Meter Reading Day",
            "ko": "검침일"
          },
          "hint": {
            "en": "Day of month when meter is read (1-31, 0 for last day)",
            "ko": "검침일 (1-31, 0은 말일)"
          },
          "value": 1,
          "min": 0,
          "max": 31
        },
        {
          "id": "tariff_type",
          "type": "dropdown",
          "label": {
            "en": "Contract Type",
            "ko": "계약종별"
          },
          "hint": {
            "en": "Your KEPCO contract type. 'Residential' uses the Voltage Type below. Non-residential types require Contract Power (kW) below, and the large-family/welfare discounts do not apply to them. Time-of-use (TOU) types (General(A)II, Industrial(A)II) are estimated by bucketing real-time usage into off/mid/peak periods from installation onward — accurate from the first full billing period after install.",
            "ko": "한전 계약종별입니다. '주택용'은 아래 '전압 구분'을 사용합니다. 비주택용 종별은 아래 '계약전력(kW)' 입력이 필요하며, 대가족·복지 할인은 주택용에만 적용됩니다. 시간대별(TOU) 종별(일반용(갑)Ⅱ·산업용(갑)Ⅱ)은 설치 이후 실시간 사용량을 경/중/최대부하로 집계해 계산합니다(설치 후 첫 완전한 청구기간부터 정확)."
          },
          "value": "residential",
          "values": [
            { "id": "residential", "label": { "en": "Residential", "ko": "주택용" } },
            { "id": "general_gap1_low", "label": { "en": "General (A) I - Low", "ko": "일반용(갑)Ⅰ 저압" } },
            { "id": "general_gap1_highA_s1", "label": { "en": "General (A) I - High A, Opt.I", "ko": "일반용(갑)Ⅰ 고압A 선택Ⅰ" } },
            { "id": "general_gap1_highA_s2", "label": { "en": "General (A) I - High A, Opt.II", "ko": "일반용(갑)Ⅰ 고압A 선택Ⅱ" } },
            { "id": "general_gap1_highB_s1", "label": { "en": "General (A) I - High B, Opt.I", "ko": "일반용(갑)Ⅰ 고압B 선택Ⅰ" } },
            { "id": "general_gap1_highB_s2", "label": { "en": "General (A) I - High B, Opt.II", "ko": "일반용(갑)Ⅰ 고압B 선택Ⅱ" } },
            { "id": "edu_gap_low", "label": { "en": "Education (A) - Low", "ko": "교육용(갑) 저압" } },
            { "id": "edu_gap_highA_s1", "label": { "en": "Education (A) - High A, Opt.I", "ko": "교육용(갑) 고압A 선택Ⅰ" } },
            { "id": "edu_gap_highA_s2", "label": { "en": "Education (A) - High A, Opt.II", "ko": "교육용(갑) 고압A 선택Ⅱ" } },
            { "id": "edu_gap_highB_s1", "label": { "en": "Education (A) - High B, Opt.I", "ko": "교육용(갑) 고압B 선택Ⅰ" } },
            { "id": "edu_gap_highB_s2", "label": { "en": "Education (A) - High B, Opt.II", "ko": "교육용(갑) 고압B 선택Ⅱ" } },
            { "id": "ind_gap1_low", "label": { "en": "Industrial (A) I - Low", "ko": "산업용(갑)Ⅰ 저압" } },
            { "id": "ind_gap1_highA_s1", "label": { "en": "Industrial (A) I - High A, Opt.I", "ko": "산업용(갑)Ⅰ 고압A 선택Ⅰ" } },
            { "id": "ind_gap1_highA_s2", "label": { "en": "Industrial (A) I - High A, Opt.II", "ko": "산업용(갑)Ⅰ 고압A 선택Ⅱ" } },
            { "id": "ind_gap1_highB_s1", "label": { "en": "Industrial (A) I - High B, Opt.I", "ko": "산업용(갑)Ⅰ 고압B 선택Ⅰ" } },
            { "id": "ind_gap1_highB_s2", "label": { "en": "Industrial (A) I - High B, Opt.II", "ko": "산업용(갑)Ⅰ 고압B 선택Ⅱ" } },
            { "id": "general_gap2_highA_s1", "label": { "en": "General (A) II TOU - High A, Opt.I", "ko": "일반용(갑)Ⅱ 고압A 선택Ⅰ (시간대별)" } },
            { "id": "general_gap2_highA_s2", "label": { "en": "General (A) II TOU - High A, Opt.II", "ko": "일반용(갑)Ⅱ 고압A 선택Ⅱ (시간대별)" } },
            { "id": "general_gap2_highB_s1", "label": { "en": "General (A) II TOU - High B, Opt.I", "ko": "일반용(갑)Ⅱ 고압B 선택Ⅰ (시간대별)" } },
            { "id": "general_gap2_highB_s2", "label": { "en": "General (A) II TOU - High B, Opt.II", "ko": "일반용(갑)Ⅱ 고압B 선택Ⅱ (시간대별)" } },
            { "id": "ind_gap2_highA_s1", "label": { "en": "Industrial (A) II TOU - High A, Opt.I", "ko": "산업용(갑)Ⅱ 고압A 선택Ⅰ (시간대별)" } },
            { "id": "ind_gap2_highA_s2", "label": { "en": "Industrial (A) II TOU - High A, Opt.II", "ko": "산업용(갑)Ⅱ 고압A 선택Ⅱ (시간대별)" } },
            { "id": "ind_gap2_highB_s1", "label": { "en": "Industrial (A) II TOU - High B, Opt.I", "ko": "산업용(갑)Ⅱ 고압B 선택Ⅰ (시간대별)" } },
            { "id": "ind_gap2_highB_s2", "label": { "en": "Industrial (A) II TOU - High B, Opt.II", "ko": "산업용(갑)Ⅱ 고압B 선택Ⅱ (시간대별)" } },
            { "id": "farm_gap", "label": { "en": "Agricultural (A)", "ko": "농사용(갑)" } },
            { "id": "farm_eul_low", "label": { "en": "Agricultural (B) - Low", "ko": "농사용(을) 저압" } },
            { "id": "farm_eul_high", "label": { "en": "Agricultural (B) - High", "ko": "농사용(을) 고압" } },
            { "id": "night_gap", "label": { "en": "Off-peak (A)", "ko": "심야전력(갑)" } }
          ]
        },
        {
          "id": "pressure",
          "type": "dropdown",
          "label": {
            "en": "Voltage Type (Residential only)",
            "ko": "전압 구분 (주택용 전용)"
          },
          "hint": {
            "en": "Only used when Contract Type is Residential. Low voltage is used in most detached houses; high voltage is mainly used in apartments. Ignored for other contract types.",
            "ko": "계약종별이 '주택용'일 때만 사용됩니다. 저압은 일반 단독주택, 고압은 주로 아파트에서 사용합니다. 다른 계약종별에서는 무시됩니다."
          },
          "value": "low",
          "values": [
            {
              "id": "low",
              "label": {
                "en": "Low Voltage (Residential)",
                "ko": "저압 (주택용)"
              }
            },
            {
              "id": "high",
              "label": {
                "en": "High Voltage (Residential)",
                "ko": "고압 (주택용)"
              }
            }
          ]
        },
        {
          "id": "contract_kw",
          "type": "number",
          "label": {
            "en": "Contract Power (kW)",
            "ko": "계약전력 (kW)"
          },
          "hint": {
            "en": "Required for non-residential contract types: basic charge = won/kW x contract power. Leave 0 for Residential and Off-peak (A).",
            "ko": "비주택용 계약종별의 기본요금 계산에 필요합니다 (기본요금 = 원/kW × 계약전력). 주택용과 심야전력(갑)은 0으로 두세요."
          },
          "value": 0,
          "min": 0,
          "decimals": 1
        },
        {
          "id": "budget_won",
          "type": "number",
          "label": {
            "en": "Monthly Budget (won)",
            "ko": "월 목표 예산 (원)"
          },
          "hint": {
            "en": "Optional. Sets a monthly bill budget. The 'Budget Usage' sensor shows this-month-cost/budget %, and the 'forecast exceeds budget' flow trigger fires when the month-end forecast rises above it. 0 disables it.",
            "ko": "선택 사항. 월 요금 목표 예산을 설정합니다. '예산 대비' 센서가 이번달 사용량 요금/예산 비율(%)을 표시하고, '예상 요금이 예산 초과' 플로우 트리거(월말 전망 기준)가 실행됩니다. 0이면 비활성화."
          },
          "value": 0,
          "min": 0,
          "step": 1000
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Climate/Fuel Adjustment Rates",
        "ko": "기후환경·연료비조정 단가"
      },
      "children": [
        {
          "id": "use_auto_adjustment",
          "type": "checkbox",
          "label": {
            "en": "Use built-in rates (auto)",
            "ko": "내장 요율 자동 사용"
          },
          "hint": {
            "en": "When on (default), the climate/environment fee and fuel-cost adjustment use the app's built-in latest KEPCO rates. Turn off to enter them manually below (e.g. after a KEPCO change before the app is updated).",
            "ko": "켜짐(기본)이면 기후환경요금·연료비조정 단가를 앱 내장 최신 요율로 자동 사용합니다. 끄면 아래에 직접 입력한 값을 사용합니다 (앱 업데이트 전에 한전이 요율을 바꾼 경우 등)."
          },
          "value": true
        },
        {
          "id": "climate_price",
          "type": "number",
          "label": {
            "en": "Climate/Environment Fee (won/kWh)",
            "ko": "기후환경요금 단가 (원/kWh)"
          },
          "hint": {
            "en": "Used only when 'Use built-in rates' is off. KEPCO 2024-2026: 9.0 won/kWh.",
            "ko": "'내장 요율 자동 사용'이 꺼졌을 때만 적용됩니다. 한전 2024~2026년 기준 9.0원/kWh."
          },
          "value": 9,
          "min": 0,
          "decimals": 1
        },
        {
          "id": "fuel_price",
          "type": "number",
          "label": {
            "en": "Fuel Cost Adjustment (won/kWh)",
            "ko": "연료비조정 단가 (원/kWh)"
          },
          "hint": {
            "en": "Used only when 'Use built-in rates' is off. Capped at +/-5 won/kWh (currently +5).",
            "ko": "'내장 요율 자동 사용'이 꺼졌을 때만 적용됩니다. ±5원/kWh 상한 (현재 +5)."
          },
          "value": 5,
          "min": -5,
          "max": 5,
          "decimals": 1
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Solar (Net Metering)",
        "ko": "태양광 (상계)"
      },
      "children": [
        {
          "id": "solar_offset",
          "type": "checkbox",
          "label": {
            "en": "Subtract exported (solar) energy",
            "ko": "송전(태양광) 사용량 차감"
          },
          "hint": {
            "en": "If your source device reports exported energy (meter_power.exported), enable this to bill on net usage (consumption minus exported). Approximates KEPCO net metering (no surplus carryover). Not combined with time-of-use tariffs.",
            "ko": "소스 기기가 송전량(meter_power.exported)을 제공하면, 켜서 순사용량(소비 − 송전)으로 요금을 계산합니다. 한전 상계거래 근사(잉여 이월 미반영). 시간대별(TOU) 종별과는 결합되지 않습니다."
          },
          "value": false
