{
  "name": {
    "en": "Korea Electricity Meter",
    "ko": "한국 전력 요금 계산기"
  },
  "class": "sensor",
  "capabilities": [
    "meter_money_this_month",
    "meter_kwh_this_month",
    "kwh_step",
    "meter_tariff",
    "meter_kwh_this_hour",
    "meter_kwh_last_hour",
    "meter_kwh_today",
    "meter_kwh_last_day",
    "meter_kwh_daily_avg",
    "meter_month_comparison",
    "meter_kwh_forecast",
    "meter_money_forecast",
    "meter_kwh_last_month",
    "meter_money_last_month",
    "meter_kwh_this_year",
    "meter_money_this_year",
    "meter_power"
  ],
  "capabilitiesOptions": {
    "meter_power": {
      "title": {
        "en": "Total Energy",
        "ko": "총 사용량"
      },
      "decimals": 2
    },
    "meter_kwh_this_month": {
      "title": {
        "en": "This Month",
        "ko": "이번달 사용량"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 1
    },
    "meter_kwh_this_year": {
      "title": {
        "en": "This Year",
        "ko": "올해 사용량"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 1
    },
    "meter_kwh_this_hour": {
      "title": {
        "en": "This Hour Usage",
        "ko": "이번 시간 사용"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 2
    },
    "meter_kwh_last_hour": {
      "title": {
        "en": "Last Hour Usage",
        "ko": "지난 시간 사용"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 2
    },
    "meter_kwh_last_day": {
      "title": {
        "en": "Yesterday Usage",
        "ko": "어제 사용"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 1
    },
    "meter_kwh_last_month": {
      "title": {
        "en": "Last Month Usage",
        "ko": "지난달 사용"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 1
    },
    "meter_money_this_month": {
      "title": {
        "en": "This Month Cost",
        "ko": "이번달 예상 요금"
      }
    },
    "meter_money_this_year": {
      "title": {
        "en": "This Year Cost",
        "ko": "올해 누적 요금"
      }
    },
    "meter_tariff": {
      "title": {
        "en": "Current Rate",
        "ko": "현재 단가"
      },
      "units": {
        "en": "₩/kWh"
      },
      "decimals": 1
    },
    "kwh_step": {
      "title": {
        "en": "Progressive Step",
        "ko": "누진 단계"
      },
      "decimals": 0
    },
    "meter_money_last_month": {
      "title": {
        "en": "Last Month Cost",
        "ko": "지난달 요금"
      }
    },
    "meter_kwh_forecast": {
      "title": {
        "en": "Forecast Usage",
        "ko": "예상 사용량"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 1
    },
    "meter_money_forecast": {
      "title": {
        "en": "Forecast Cost",
        "ko": "예상 요금"
      }
    },
    "meter_kwh_today": {
      "title": {
        "en": "Today Usage",
        "ko": "오늘 사용량"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 2
    },
    "meter_kwh_daily_avg": {
      "title": {
        "en": "Daily Average",
        "ko": "일평균 사용량"
      },
      "units": {
        "en": "kWh"
      },
      "decimals": 2
    },
    "meter_month_comparison": {
      "title": {
        "en": "vs Last Month",
        "ko": "지난달 대비"
      },
      "units": {
        "en": "%"
      },
      "decimals": 1
    }
